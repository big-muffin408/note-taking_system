# Application
WEB_PORT=5173
NGINX_PORT=80
USER_SERVICE_PORT=3001
DOCUMENT_SERVICE_PORT=3002
AI_SERVICE_PORT=3003
COLLAB_SERVICE_PORT=3004
SYNC_SERVICE_PORT=3005

# Databases
MYSQL_ROOT_PASSWORD=notes_root_password
MYSQL_DATABASE=notes
MYSQL_USER=notes_user
MYSQL_PASSWORD=notes_password
MYSQL_PORT=3306

MONGO_INITDB_ROOT_USERNAME=notes_admin
MONGO_INITDB_ROOT_PASSWORD=notes_password
MONGO_PORT=27017

REDIS_PORT=6379

# Object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=notes-assets

# Docker build apt mirror — root host only; Dockerfiles append /debian or /ubuntu.
# APT_MIRROR=http://mirrors.aliyun.com
# Docker build pip index mirror — used by the mineru-api image build (mineru[core], torch...).
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/

# AI providers
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=
# Xiaomi MIMO example:
# AI_PROVIDER=xiaomi
# AI_API_KEY=your-xiaomi-mimo-api-key
# AI_MODEL=mimo-v2.5-pro
# AI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MINERU_COMMAND=mineru
MINERU_BACKEND=pipeline
MINERU_LANGUAGE=ch
MINERU_TIMEOUT_SECONDS=1200
MINERU_API_URL=
# Chroma vector store (AI service built-in, persisted via Docker volume)
CHROMA_COLLECTION=note_chunks
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
MINERU_API_PORT=8000
MINERU_MODEL_SOURCE=modelscope
MINERU_SHM_SIZE=8gb
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
AI_SERVICE_URL=http://localhost:3003

# Auth (required - docker compose refuses to start without it;
# use a strong value in production: openssl rand -base64 32)
JWT_SECRET=dev-jwt-secret-change-in-production

# Internal service-to-service authentication (set a strong random value in production)
INTERNAL_SERVICE_SECRET=
AI_SERVICE_SECRET=

# CORS (comma-separated origins, defaults to localhost)
ALLOWED_ORIGINS=
APP_BASE_URL=http://localhost
SERVER_PUBLIC_URL=http://localhost
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/user/google/callback

# Email verification
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
EMAIL_VERIFICATION_TTL_MINUTES=10
EMAIL_VERIFICATION_COOLDOWN_SECONDS=60
