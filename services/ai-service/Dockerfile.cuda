# syntax=docker/dockerfile:1.7
FROM vllm/vllm-openai:latest

WORKDIR /app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV VLLM_ENABLE_CUDA_COMPATIBILITY=1
ENV PIP_DISABLE_PIP_VERSION_CHECK=1
ENV PIP_DEFAULT_TIMEOUT=120
ENV UV_LINK_MODE=copy

ENTRYPOINT []

RUN apt-get update \
    && apt-get install -y --no-install-recommends libgl1 libglib2.0-0 fonts-noto-cjk \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-cuda.txt constraints-cuda.txt ./
RUN --mount=type=cache,target=/root/.cache/pip \
    --mount=type=cache,target=/root/.cache/uv \
    pip install --upgrade pip setuptools wheel uv \
    && uv pip install --system -c constraints-cuda.txt -r requirements-cuda.txt

COPY app ./app
EXPOSE 3003
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "3003"]
