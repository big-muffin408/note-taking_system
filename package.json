{
  "name": "ai-collaborative-note-system",
  "version": "0.1.0",
  "private": true,
  "description": "AI enhanced collaborative Markdown note-taking system monorepo.",
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:electron": "npm run dev:electron --workspace @notes/web",
    "start:all": "bash scripts/start-all.sh",
    "build": "npm run build --workspaces --if-present",
    "build:desktop": "npm run build:desktop --workspace @notes/web",
    "build:desktop:win": "npm run build:desktop --workspace @notes/web -- --win",
    "build:desktop:mac": "npm run build:desktop --workspace @notes/web -- --mac",
    "build:desktop:linux": "npm run build:desktop --workspace @notes/web -- --linux",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "docker:up": "docker compose up --build",
    "docker:up:mineru": "docker compose -f docker-compose.yml -f docker-compose.mineru.yml up --build",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
